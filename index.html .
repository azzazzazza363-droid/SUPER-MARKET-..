.icon-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 15px;
    padding: 20px;
}

.icon {
    width: 90%;
    height: 300px;
    background-color: #f0f0f0;
    border: 3px solid #333;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24px;
    font-weight: bold;
}
        body { font-family: sans-serif; background: #f4f4f4; padding: 15px; }
        .product-item { display: flex; align-items: center; background: #fff; padding: 10px; margin-bottom: 5px; border-radius: 5px; border: 1px solid #ddd; }
        .product-item img { width: 100px; height: 100px; object-fit: cover; margin-left: 10px; border-radius: 4px; }
        .product-info { flex-grow: 1; font-weight: bold; }
        input { width: 50px; padding: 5px; }
        #cart { margin-top: 20px; padding: 15px; background: #fff; border: 2px solid #27ae60; border-radius: 10px; }
        /* كود التصميم الجديد */
.section { display: none; padding: 20px; }
.active { display: block; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
button { padding: 10px; margin: 5px; cursor: pointer; border-radius: 8px; border: 1px solid #ddd; background: #fff; }
.cart-btn { background-color: #4CAF50; color: white; width: 100%; margin-top: 20px; }
.back-btn { background-color: #f44336; color: white; }
    </style>
</head>

                catContainer.innerHTML += `
                    <div class="product-item">
                        <img src="${i.img || 'https://via.placeholder.com/50'}">
                        <div class="product-info">${i.n} - ${i.p} ل.س</div>
                        <input type="number" min="0" onchange="addToCart('${i.n}', ${i.p}, this.value)">
                    </div>`;
            });
        });

        function addToCart(n, p, q) {
            if(q > 0) cart[n] = {p, q}; else delete cart[n];
            let list = document.getElementById('cart-list');
            list.innerHTML = "";
            for(let i in cart) list.innerHTML += `<div>${i}: ${cart[i].q} قطعة</div>`;
        }

        function sendOrder() {
            let n = document.getElementById('custName').value, a = document.getElementById('custAddress').value;
            if(!n || !a) return alert("يرجى تعبئة الاسم والعنوان");
            let msg = `طلب جديد:%0Aالاسم: ${n}%0Aالعنوان: ${a}%0A%0Aالطلبات:%0A`;
            for(let i in cart) msg += `${i}: ${cart[i].q}%0A`;
            window.open("https://wa.me/963952307348?text=" + msg);
        }
